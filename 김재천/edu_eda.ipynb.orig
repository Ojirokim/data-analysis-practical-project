    "    y='nevents', \n",
    "    palette=['#f38ba8', '#a6e3a1'],  # 붉은색(실패) vs 녹색(성공)\n",
    "    showfliers=False,                # 극단적인 출석왕(이상치) 점들을 지워줌\n",
    "    width=0.5,\n",
    "    ax=ax\n",
    ")\n",
