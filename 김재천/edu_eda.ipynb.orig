   "source": [
    "## high risk/normal 집단 exp 전환율 비교"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 294,
   "id": "c67fd1dd",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1800x800 with 8 Axes>"
      ]
     },
     "metadata": {},
