  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "5074682f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "grade                   float64\n",
      "start_time_DI    datetime64[us]\n",
      "last_event_DI    datetime64[us]\n",
      "dtype: object\n"
     ]
    }
   ],
   "source": [
    "# grade: 문자 → 숫자 (변환 불가값은 NaN 처리)\n",
    "df['grade'] = pd.to_numeric(df['grade'], errors='coerce')\n",
    "\n",
    "# 날짜 변환\n",
    "df['start_time_DI'] = pd.to_datetime(df['start_time_DI'], errors='coerce')\n",
    "df['last_event_DI'] = pd.to_datetime(df['last_event_DI'], errors='coerce')\n",
    "\n",
    "# 검증\n",
    "print(df[['grade', 'start_time_DI', 'last_event_DI']].dtypes)"
   ]
  },
