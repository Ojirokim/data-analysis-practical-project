   "source": [
    "funnel_cols = ['registered', 'viewed', 'explored', 'certified']\n",
    "funnel_counts = df[funnel_cols].sum()\n",
    "funnel_rates = (funnel_counts / len(df) * 100).round(2)\n",
    "\n",
    "funnel_summary = pd.DataFrame({\n",
    "    '인원 수': funnel_counts.astype(int),\n",
    "    '비율(%)': funnel_rates\n",
    "})\n",
    "display(funnel_summary)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 22,
   "id": "65e40189",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x500 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "colors = ['#f38ba8', '#fab387', '#f9e2af', '#a6e3a1']\n",
    "ax.bar(funnel_summary.index, funnel_summary['인원 수'], color=colors)\n",
    "\n",
    "for i, (cnt, pct) in enumerate(zip(funnel_summary['인원 수'], funnel_rates)):\n",
    "    ax.text(i, cnt + cnt*0.02, f\"{cnt:,}\\n({pct}%)\", ha='center', fontsize=10)\n",
    "\n",
    "ax.set_title('학습 퍼널 단계별 인원', fontsize=14, fontweight='bold')\n",
    "ax.set_ylabel('학습자 수')\n",
    "ax.yaxis.set_major_formatter(mticker.FuncFormatter(lambda x, _: f'{int(x):,}'))\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
