   "source": [
    "### 행동 지표와 exp 전환율의 상관행렬"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 204,
   "id": "466fe588",
   "metadata": {},
   "outputs": [
    {
     "data": {
