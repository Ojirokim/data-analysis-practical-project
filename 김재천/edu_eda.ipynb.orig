   "source": [
    "missing = df.isnull().sum()\n",
    "missing_pct = (missing / len(df) * 100).round(2)\n",
    "missing_df = pd.DataFrame({\n",
    "    '결측 수': missing,\n",
    "    '결측률(%)': missing_pct\n",
    "}).sort_values('결측률(%)', ascending=False)\n",
    "missing_df[missing_df['결측 수'] > 0]"
   ]
  },
