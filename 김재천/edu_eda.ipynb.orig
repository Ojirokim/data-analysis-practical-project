     "text": [
      "exam_flag × certified Cramer's V: 0.055\n"
     ]
    }
   ],
   "source": [
    "# 수료 여부와 exam_flag의 관계를 확인해보는 것이 더 흥미로울 수 있음\n",
    "cross_cert = pd.crosstab(df['exam_flag'], df['certified'])\n",
    "chi2, p_val, dof, expected = stats.chi2_contingency(cross_cert)\n",
    "cramers_v_cert = np.sqrt(chi2 / (cross_cert.sum().sum() * (min(cross_cert.shape)-1)))\n",
    "print(f\"exam_flag × certified Cramer's V: {cramers_v_cert:.3f}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 242,
   "id": "0ed43f16",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 이걸 확인해보시면 훨씬 강한 연관성이 나올 가능성이 높습니다\n",
    "# grade(점수)가 임계값 이상인지 여부 × certified\n",
    "df['pass_grade'] = (df['grade'].astype(float) >= 0.5).astype(int)\n"
   ]
  },
