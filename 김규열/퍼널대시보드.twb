          <datasource-dependencies datasource='federated.15kvnc50i8uj3j1dhjs621djx8ky'>
            <column caption='Course Filter' datatype='boolean' name='[Calculation_2072081362505728]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;All&quot; THEN TRUE&#13;&#10;ELSE [Calculation_2072081364717569] = [Parameters].[Parameter 1]&#13;&#10;END' />
            </column>
            <column caption='Course Name Clean' datatype='string' name='[Calculation_2072081364717569]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Calculation_2072081366052866]&#13;&#10;&#13;&#10;WHEN &quot;HarvardX - CS50x&quot; THEN &quot;Harvard - Introduction to Computer Science&quot;&#13;&#10;WHEN &quot;HarvardX - CB22x&quot; THEN &quot;Harvard - The Ancient Greek Hero&quot;&#13;&#10;WHEN &quot;HarvardX - ER22x&quot; THEN &quot;Harvard - Justice&quot;&#13;&#10;WHEN &quot;HarvardX - PH207x&quot; THEN &quot;Harvard - Health in Numbers&quot;&#13;&#10;WHEN &quot;HarvardX - PH278x&quot; THEN &quot;Harvard - Human Health&quot;&#13;&#10;&#13;&#10;WHEN &quot;MITx - 6.00x&quot; THEN &quot;MIT - Intro to CS&quot;&#13;&#10;WHEN &quot;MITx - 6.002x&quot; THEN &quot;MIT - Circuits and Electronics&quot;&#13;&#10;WHEN &quot;MITx - 3.091x&quot; THEN &quot;MIT - Solid-State Chemistry&quot;&#13;&#10;WHEN &quot;MITx - 2.01x&quot; THEN &quot;MIT - Elements of Structures&quot;&#13;&#10;WHEN &quot;MITx - 7.00x&quot; THEN &quot;MIT - Introduction to Biology&quot;&#13;&#10;WHEN &quot;MITx - 8.02x&quot; THEN &quot;MIT - Electricity and Magnetism&quot;&#13;&#10;WHEN &quot;MITx - 8.MReV&quot; THEN &quot;MIT - Mechanics ReView&quot;&#13;&#10;WHEN &quot;MITx - 14.73x&quot; THEN &quot;MIT - The Challenges of Global Poverty&quot;&#13;&#10;ELSE [Calculation_2072081366052866]&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Course Code' datatype='string' name='[Calculation_2072081366052866]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='SPLIT([course_id], &quot;/&quot;, 1) + &quot; - &quot; + SPLIT([course_id], &quot;/&quot;, 2)' />
            </column>
            <column caption='Course Id' datatype='string' name='[course_id]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_2072081362505728]' derivation='None' name='[none:Calculation_2072081362505728:nk]' pivot='key' type='nominal' />
            <column caption='Registered' datatype='integer' name='[registered]' role='measure' type='quantitative' />
            <column-instance column='[viewed_rate (copy)_1817819292450821]' derivation='User' name='[usr:viewed_rate (copy)_1817819292450821:qk]' pivot='key' type='quantitative' />
            <column caption='Viewed' datatype='integer' name='[viewed]' role='measure' type='quantitative' />
            <column caption='viewed이탈률' datatype='real' name='[viewed_rate (copy)_1817819292450821]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='1-SUM([viewed]) / SUM([registered])' />
            </column>
